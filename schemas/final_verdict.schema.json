{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinalVerdict",
  "type": "object",
  "required": [
    "status",
    "heuristic_scores",
    "score_basis",
    "blocking_issues",
    "residual_warnings",
    "recommended_next_action",
    "release_note"
  ],
  "properties": {
    "status": {
      "enum": [
        "pass",
        "conditional_pass",
        "revise_required",
        "fail"
      ]
    },
    "heuristic_scores": {
      "type": "object",
      "required": [
        "factuality",
        "logic",
        "style",
        "readability",
        "traceability",
        "risk"
      ],
      "properties": {
        "factuality": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "logic": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "style": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "readability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "traceability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "risk": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "score_basis": {
      "type": "object",
      "required": [
        "type",
        "calibrated_quality_measure",
        "note"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "calibrated_quality_measure": {
          "const": false
        },
        "note": {
          "type": "string"
        }
      }
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "residual_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_next_action": {
      "type": "string"
    },
    "release_note": {
      "type": "string"
    }
  }
}
